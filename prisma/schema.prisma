generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= AUTH =============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  handle        String?   @unique
  bio           String?
  location      String?
  /** Linked Telegram user id — same person can chat AI agent via web or Telegram. */
  telegramUserId   String? @unique
  telegramUsername String?
  /** Default community for cross-channel agent context (optional). */
  defaultCommunityId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  memberships      Membership[]
  ownedCommunities Community[]        @relation("CommunityOwner")
  posts            Post[]
  comments         Comment[]
  reactions        Reaction[]
  votes            Vote[]
  messages         Message[]
  courseProgress   CourseProgress[]
  challengeMembers ChallengeMember[]
  taskCompletions  TaskCompletion[]
  checkins         Checkin[]
  reviewedCheckins Checkin[]          @relation("CheckinReviewer")
  submissionVotes  SubmissionVote[]
  checkinVotes     CheckinVote[]
  notifications    Notification[]     @relation("NotifRecipient")
  triggeredNotifs  Notification[]     @relation("NotifActor")
  bookmarks        Bookmark[]
  follows          Follow[]           @relation("FollowFollower")
  followers        Follow[]           @relation("FollowFollowee")
  featureReadStates FeatureReadState[]
  purchases        Purchase[]
  xpLedger         XPLedger[]
  badgeAwards      BadgeAward[]
  affiliateLinks   AffiliateLink[]
  referrals        Referral[]
  agentConversations AgentConversation[]
  apiKeys          ApiKey[]
  ownedEvents      Event[]
  eventBookings    EventBooking[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============= COMMUNITY =============

model Community {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  tagline     String?
  description String?  @db.Text
  bannerUrl   String?
  iconUrl     String?
  ownerId     String

  classesConfig Json?
  pillarsConfig Json?
  gemsConfig    Json?
  levelsConfig  Json?
  bossConfig    Json?
  /** Subscription tier config — defines tiers + pricing + gates */
  tiersConfig   Json?
  billingModel  Json?
  /** UI visibility config — { hiddenFeatures: FeatureKey[] } */
  uiConfig      Json?

  /** Affiliate program config — { enabled, commissionPercent, cookieDays } */
  affiliateConfig Json?

  /** External notification channels — { discord?: { webhookUrl, eventTypes }, telegram?: { botToken, chatId, eventTypes } } */
  channelConfig Json?

  /** Agency tier toggle — hide focus.camp brand footer */
  whiteLabel    Boolean @default(false)

  /** Platform-level plan tier paid by owner: SOLO | PRO | AGENCY | GRANDFATHER */
  planTier      String  @default("SOLO")
  /** Null = not active yet (PENDING payment) OR grandfathered (lifetime free). Otherwise expiry date. */
  planExpiresAt DateTime?

  /** AI Agent system prompt configured by owner. Empty = generic helper. */
  agentSystemPrompt String? @db.Text
  /** Encrypted Anthropic API key for per-community AI Agent. */
  agentApiKey       String? @db.Text

  category         String?
  featuredOnGlobal Boolean @default(false)
  slugChangedAt    DateTime?
  introVideoUrl    String?
  introGallery     Json?

  memberCount Int @default(0)
  onlineCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner         User           @relation("CommunityOwner", fields: [ownerId], references: [id])
  memberships   Membership[]
  channels      Channel[]
  courses       Course[]
  challenges    Challenge[]
  posts         Post[]
  products      Product[]
  badges        Badge[]
  subscriptions Subscription[]
  xpLedgers     XPLedger[]
  agentConversations AgentConversation[]
  apiKeys       ApiKey[]
  events        Event[]
  featureReadStates FeatureReadState[]
  affiliateLinks AffiliateLink[]

  @@index([featuredOnGlobal, createdAt])
}

model Membership {
  id           String   @id @default(cuid())
  userId       String
  communityId  String
  role         String   @default("MEMBER")
  tier         String   @default("EXPLORER")
  className    String?
  xp           Int      @default(0)
  level        Int      @default(1)
  aip          Int      @default(0)
  gems         Int      @default(0)
  streakDays   Int      @default(0)
  lastActiveAt DateTime @default(now())
  joinedAt     DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@index([communityId, xp])
}

model FeatureReadState {
  id           String   @id @default(cuid())
  userId       String
  communityId  String
  featureKey   String
  lastViewedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId, featureKey])
  @@index([communityId, featureKey, lastViewedAt])
}

// ============= CHAT =============

model Channel {
  id           String  @id @default(cuid())
  communityId  String
  name         String
  slug         String
  topic        String?
  category     String?
  position     Int     @default(0)
  type         String  @default("TEXT")
  isPrivate    Boolean @default(false)
  requiredTier String?

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([communityId, slug])
}

model Message {
  id        String    @id @default(cuid())
  channelId String
  userId    String
  content   String    @db.Text
  replyToId String?
  editedAt  DateTime?
  createdAt DateTime  @default(now())

  channel Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo Message?  @relation("MessageReply", fields: [replyToId], references: [id])
  replies Message[] @relation("MessageReply")

  @@index([channelId, createdAt])
}

// ============= COURSES =============

model Course {
  id           String   @id @default(cuid())
  communityId  String
  slug         String
  title        String
  description  String?  @db.Text
  thumbnailUrl String?
  pillar       String?
  level        String   @default("BASIC")
  requiredTier String?
  xpReward     Int      @default(0)
  aipReward    Int      @default(0)
  isPublished  Boolean  @default(false)
  /** Owner opt-in: include this course on the global marketplace. */
  featuredOnGlobal Boolean @default(false)
  createdAt    DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@unique([communityId, slug])
  @@index([featuredOnGlobal, createdAt])
}

model Lesson {
  id          String  @id @default(cuid())
  courseId    String
  title       String
  description String? @db.Text
  content     String? @db.Text
  videoUrl    String?
  duration    Int?
  position    Int     @default(0)
  xpReward    Int     @default(0)

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress CourseProgress[]
}

model CourseProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// ============= CHALLENGES =============

model Challenge {
  id             String    @id @default(cuid())
  communityId    String
  slug           String
  title          String
  description    String?   @db.Text
  bannerUrl      String?
  difficulty     String    @default("NORMAL")
  requiredDays   Int       @default(21)
  maxMembers     Int       @default(999)
  depositAip     Int?
  priceVnd       Decimal?  @db.Decimal(15, 2)
  leaderId       String?
  status         String    @default("OPEN")
  startsAt       DateTime?
  endsAt         DateTime?
  freezeFromDay  Int?
  freezeStartsAt DateTime?
  freezeEndsAt   DateTime?
  requiresApproval Boolean @default(false)
  /** Owner opt-in: include this challenge on the global marketplace. */
  featuredOnGlobal Boolean @default(false)
  /** Subscription tier required to join. Null = free for any member. */
  requiredTier   String?
  /** Tiered pricing config. Null = free join. Shape: PricingConfig in lib/services/pricing.ts */
  pricingConfig  Json?
  /** When true, members only see tasks up to their current day — future tasks are hidden. */
  hideFutureTasks Boolean @default(false)
  /** Task unlock mode: ALL (all visible), DAILY (time-based), SEQUENTIAL (complete prev first), MANUAL (admin unlocks) */
  taskUnlockMode  String  @default("DAILY")
  /** Default hours between task unlocks (used in DAILY mode). Default 24. */
  unlockIntervalHours Int @default(24)
  /** Multiple freeze windows. Array of {label?: string, startsAt: string, endsAt: string} */
  freezeWindows  Json?
  /** Long-form sales pitch shown on challenge page to non-members. Markdown supported. */
  pitch          String?   @db.Text
  bumpProductId  String?
  createdAt      DateTime  @default(now())

  community   Community         @relation(fields: [communityId], references: [id], onDelete: Cascade)
  tasks       ChallengeTask[]
  members     ChallengeMember[]
  checkins    Checkin[]
  products    ChallengeProduct[]
  bumpProduct Product?          @relation("ChallengeBump", fields: [bumpProductId], references: [id])

  @@unique([communityId, slug])
  @@index([featuredOnGlobal, createdAt])
}

// Cross-link between Challenges and Products in Marketplace.
// Used for "Equipment / Trang bị hỗ trợ" on challenge detail page
// and "Giúp cho challenge: ..." tag on product detail page.
model ChallengeProduct {
  challengeId String
  productId   String
  relevance   String   @default("RECOMMENDED") // REQUIRED | RECOMMENDED | OPTIONAL
  createdAt   DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([challengeId, productId])
  @@index([productId])
}

model ChallengeTask {
  id            String    @id @default(cuid())
  challengeId   String
  dayNumber     Int
  label         String?
  title         String
  description   String?   @db.Text
  sopContent    String?   @db.Text
  videoUrl      String?
  meetingAt     DateTime?
  evidenceType  String    @default("TEXT")
  evidenceLabel String?   @db.Text
  /** Per-task unlock override in hours. Null = use challenge default. */
  unlockAfterHours Int?

  challenge   Challenge        @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  completions TaskCompletion[]
  checkins    Checkin[]

  @@unique([challengeId, dayNumber])
}

model ChallengeMember {
  id                String    @id @default(cuid())
  challengeId       String
  userId            String
  classAtJoin       String?
  status            String    @default("PENDING")
  joinedAt          DateTime  @default(now())
  approvedAt        DateTime?
  approvedById      String?
  rejectNote        String?   @db.Text
  personalStartsAt  DateTime?
  completedAt       DateTime?
  lastCheckinAt     DateTime?
  consecutiveMissed Int       @default(0)

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

model TaskCompletion {
  id           String    @id @default(cuid())
  taskId       String
  userId       String
  evidence     String?   @db.Text
  isLate       Boolean   @default(false)
  status       String    @default("PENDING")
  rejectCount  Int       @default(0)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?   @db.Text
  createdAt    DateTime  @default(now())

  task  ChallengeTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes SubmissionVote[]

  @@unique([taskId, userId])
}

model Checkin {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  taskId      String? // links this check-in to a specific daily task (optional)
  dayNumber   Int? // redundant cache for querying by day
  content     String   @db.Text
  linkUrl     String? // external evidence URL (e.g. screenshot host, notion, miro)
  imageUrl    String? // inline image URL (uploaded/pasted)
  status       String   @default("APPROVED") // PENDING | APPROVED | REJECTED
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?  @db.Text
  rejectCount  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  challenge  Challenge      @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  task       ChallengeTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  reviewedBy User?          @relation("CheckinReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  votes      CheckinVote[]

  @@index([challengeId, createdAt])
  @@index([challengeId, userId, createdAt])
  @@index([challengeId, status])
  @@index([taskId])
}

model CheckinVote {
  id        String   @id @default(cuid())
  checkinId String
  userId    String
  createdAt DateTime @default(now())

  checkin Checkin @relation(fields: [checkinId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([checkinId, userId])
  @@index([checkinId])
}

model SubmissionVote {
  id           String   @id @default(cuid())
  completionId String
  userId       String
  createdAt    DateTime @default(now())

  completion TaskCompletion @relation(fields: [completionId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([completionId, userId])
}

// ============= CONTENT =============

model Post {
  id            String    @id @default(cuid())
  communityId   String
  userId        String
  type          String    @default("POST")
  title         String?
  body          String    @db.Text
  pillar        String?
  tags          String[]  @default([])
  isAnonymous   Boolean   @default(false)
  isPinned      Boolean   @default(false)
  isCot         Boolean   @default(false)
  cotApprovedAt DateTime?
  bountyAip     Int?
  imageUrl      String?
  viewCount     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  community Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  Comment[]
  reactions Reaction[]
  votes     Vote[]
  bookmarks Bookmark[]

  @@index([communityId, type, createdAt])
  @@index([communityId, isPinned, createdAt])
  @@index([userId, createdAt])
}

model Comment {
  id           String   @id @default(cuid())
  postId       String
  userId       String
  parentId     String?
  body         String   @db.Text
  isBestAnswer Boolean  @default(false)
  createdAt    DateTime @default(now())

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReply", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReply")

  @@index([postId, createdAt])
}

model Reaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String   // who initiated the follow
  followeeId String   // who's being followed
  createdAt  DateTime @default(now())

  follower User @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  followee User @relation("FollowFollowee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@unique([followerId, followeeId])
  @@index([followeeId, createdAt])
  @@index([followerId, createdAt])
}

model Vote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  value     Int
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// ============= MARKETPLACE =============

model Product {
  id                 String   @id @default(cuid())
  communityId        String
  slug               String
  title              String
  description        String?  @db.Text
  thumbnailUrl       String?
  type               String   @default("TEMPLATE")
  pillar             String?
  priceVnd           Decimal  @default(0) @db.Decimal(15, 2)
  priceOldVnd        Decimal? @db.Decimal(15, 2)
  isFree             Boolean  @default(false)
  isSubscription     Boolean  @default(false)
  subscriptionPeriod String?
  fileUrl            String?
  externalUrl        String?
  stock              Int?
  soldCount          Int      @default(0)
  /** Owner opt-in: include this product on the global marketplace. */
  featuredOnGlobal   Boolean  @default(false)
  /** Template for generated license keys, e.g. "FC-{XXXX}-{XXXX}". Only used when type=LICENSE. */
  licenseKeyTemplate String?
  /** Tiered pricing config. Null = use priceVnd as flat price. Shape: PricingConfig in lib/services/pricing.ts */
  pricingConfig      Json?
  isVisible          Boolean  @default(true)
  showInCartBump     Boolean  @default(false)
  bumpProductId      String?
  upsellProductId    String?
  createdAt          DateTime @default(now())

  community     Community          @relation(fields: [communityId], references: [id], onDelete: Cascade)
  purchases     Purchase[]
  challenges    ChallengeProduct[]
  bumpProduct   Product?           @relation("ProductBump", fields: [bumpProductId], references: [id])
  upsellProduct Product?           @relation("ProductUpsell", fields: [upsellProductId], references: [id])
  bumpedBy       Product[]          @relation("ProductBump")
  upsellFor      Product[]          @relation("ProductUpsell")
  challengeBumps Challenge[]        @relation("ChallengeBump")

  @@unique([communityId, slug])
  @@index([featuredOnGlobal, createdAt])
}

model Purchase {
  id         String   @id @default(cuid())
  productId  String
  userId     String
  amountVnd  Decimal  @db.Decimal(15, 2)
  paymentRef String?
  status     String   @default("PENDING")
  /** Auto-generated license key (only set for LICENSE-type products after activation). */
  licenseKey String?
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId, productId])
  @@index([productId, status])
}

// ============= PAYMENT (SePay) =============

model Payment {
  id            String   @id @default(cuid())
  paymentCode   String   @unique // unique code used in transfer content
  userId        String
  communityId   String?
  purpose       String   // subscription | product | challenge_deposit
  refType       String   // subscription | product | challenge
  refId         String   // ID của subscription/product/challenge
  amountVnd     Decimal  @db.Decimal(15, 2)
  status        String   @default("PENDING") // PENDING, COMPLETED, EXPIRED, REFUNDED
  provider      String   @default("SEPAY_STANDARD") // SEPAY_STANDARD | SEPAY_BANKHUB
  bankName      String?
  bankAccount   String?
  receivedAt    DateTime?
  transactionId String?
  metadata      Json?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([userId, status])
  @@index([refType, refId])
}

model SePayTransaction {
  id              String   @id @default(cuid())
  transactionId   String   @unique // ID từ SePay
  referenceCode   String?
  gateway         String
  accountNumber   String?
  vaNumber        String?
  paymentCode     String?
  content         String   @db.Text
  transferType    String   // credit | debit
  amount          Decimal  @db.Decimal(15, 2)
  accumulated     Decimal? @db.Decimal(15, 2)
  transactionDate DateTime
  matchedPaymentId String?
  raw             Json     // raw payload
  createdAt       DateTime @default(now())

  @@index([paymentCode])
  @@index([transactionDate])
}

// ============= NOTIFICATIONS =============

model Notification {
  id            String    @id @default(cuid())
  userId        String    // recipient
  type          String    // POST_COMMENT | POST_REACTION | COMMENT_REPLY | BEST_ANSWER | POST_COT | SUBMISSION_APPROVED | SUBMISSION_REJECTED
  title         String
  body          String?   @db.Text
  actorId       String?   // who triggered this (user who commented, reacted, etc.)
  /** Route target — e.g. /c/<slug>/p/<postId> */
  link          String?
  communitySlug String?
  postId        String?
  commentId     String?
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  user  User  @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotifActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
}

// ============= GAMIFICATION =============

model XPLedger {
  id          String   @id @default(cuid())
  userId      String
  communityId String?
  amount      Int
  reason      String
  reasonId    String?
  createdAt   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([communityId, createdAt])
}

model Badge {
  id          String  @id @default(cuid())
  communityId String?
  slug        String
  name        String
  emoji       String
  description String?
  rarity      String  @default("COMMON")
  criteria    Json

  community Community?   @relation(fields: [communityId], references: [id], onDelete: Cascade)
  awards    BadgeAward[]

  @@unique([communityId, slug])
}

model BadgeAward {
  id        String   @id @default(cuid())
  badgeId   String
  userId    String
  awardedAt DateTime @default(now())

  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([badgeId, userId])
}

// ============= BILLING =============

model Subscription {
  id          String    @id @default(cuid())
  userId      String
  communityId String
  tier        String
  status      String    @default("ACTIVE")
  startedAt   DateTime  @default(now())
  expiresAt   DateTime?
  cancelledAt DateTime?
  paymentRef  String?
  amountVnd   Decimal   @db.Decimal(15, 2)

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([userId, communityId, status])
}

// ============= AFFILIATE =============

model AffiliateLink {
  id          String   @id @default(cuid())
  userId      String
  communityId String
  code        String   @unique
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  referrals Referral[]

  @@unique([userId, communityId])
}

model Referral {
  id             String    @id @default(cuid())
  linkId         String
  referredUserId String
  convertedAt    DateTime?
  commissionVnd  Decimal?  @db.Decimal(15, 2)
  status         String    @default("PENDING")
  payoutStatus   String    @default("UNPAID")  // UNPAID | PAID | REJECTED
  payoutNote     String?
  createdAt      DateTime  @default(now())

  link         AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  referredUser User          @relation(fields: [referredUserId], references: [id])
}

// ============= AI AGENT =============

model AgentConversation {
  id          String   @id @default(cuid())
  userId      String
  communityId String
  title       String?
  /** Source channel — "web" or "telegram". Same userId can have one of each. */
  channel     String   @default("web")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  messages  AgentMessage[]

  @@index([userId, communityId, updatedAt])
  @@index([userId, channel])
}

model TelegramLinkCode {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model AgentMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user | assistant
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ============= EVENTS / CALENDAR =============

model Event {
  id          String   @id @default(cuid())
  communityId String
  ownerId     String
  type        String   @default("GROUP_LIVE") // ONE_ON_ONE | GROUP_LIVE | WORKSHOP
  title       String
  description String?  @db.Text
  startsAt    DateTime
  durationMin Int      @default(60)
  capacity    Int      @default(1)
  priceVnd    Int      @default(0)
  isFree      Boolean  @default(false)
  meetingUrl      String?
  bannerUrl       String?
  status          String   @default("OPEN") // OPEN | CANCELLED | COMPLETED
  featuredOnGlobal Boolean @default(false)
  createdAt       DateTime @default(now())
  // Google Meet integration
  meetSpaceName   String?  // e.g. "spaces/abc123" — for post-meeting API calls
  meetRecordingUrl  String? // Drive link after meeting ends
  meetTranscriptUrl String? // Google Docs transcript link
  meetEndedAt     DateTime? // actual conference end time from Meet API

  community Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  owner     User           @relation(fields: [ownerId], references: [id])
  bookings  EventBooking[]

  @@index([communityId, startsAt])
  @@index([featuredOnGlobal, startsAt])
}

model EventBooking {
  id         String   @id @default(cuid())
  eventId    String
  userId     String
  status     String   @default("PENDING") // PENDING | CONFIRMED | ATTENDED | NO_SHOW | REFUNDED
  paymentRef String?
  attendedAt DateTime? // set by Meet participants API after event ends
  createdAt  DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([userId, createdAt])
}

// ============= MCP / API KEYS =============

model ApiKey {
  id          String    @id @default(cuid())
  communityId String
  ownerId     String
  name        String
  keyHash     String    @unique
  keyPrefix   String
  scopes      String[]  @default(["read", "write", "admin"])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([keyHash])
}

model AgentToolCall {
  id           String   @id @default(cuid())
  apiKeyId     String?
  communityId  String
  userId       String?
  toolName     String
  argsJson     Json
  resultJson   Json?
  errorMessage String?
  durationMs   Int
  createdAt    DateTime @default(now())

  @@index([communityId, createdAt])
  @@index([toolName, createdAt])
  @@index([apiKeyId, createdAt])
}
